# API Gateway — Environment Variables
# Copy this file to .env for local dev, or set these in Railway dashboard

# Port to listen on (Railway sets this automatically)
PORT=3000

# Secret key — on-site Python must send this in X-API-Key header
# Leave empty to disable auth (not recommended for production)
API_KEY=change_me_to_a_random_secret

# Mark camera offline after N seconds without data
STALE_SEC=15
