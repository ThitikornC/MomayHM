# On-Site Python Backend — Environment Variables
# Copy to .env or export before running: uvicorn main:app

# Railway API Gateway URL — backend pushes camera data here every 3s
GATEWAY_URL=https://your-gateway.railway.app

# Must match API_KEY set in the Railway gateway service
GATEWAY_API_KEY=change_me_to_a_random_secret

# Push interval in seconds (default 3)
GATEWAY_INTERVAL=3
